# =============================================================
#  Licenciame – Variables de Entorno
#  Copia este archivo a .env y rellena los valores reales.
#  ¡NUNCA subas .env a git!
# =============================================================

# ── Base de datos ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/licenciame
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/licenciame

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://:yourpassword@localhost:6379/0

# ── Seguridad ──────────────────────────────────────────────
# ADVERTENCIA: Cambia estos valores en staging/production
# Genera JWT_SECRET_KEY con: openssl rand -hex 32
# Genera FERNET_KEY con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
FERNET_KEY=CHANGE_ME_use_python_cryptography_fernet_generate_key

# ── Storage ────────────────────────────────────────────────
# 'local' guarda en disco; 's3' sube a AWS S3
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# ── AWS S3 (solo si STORAGE_BACKEND=s3) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=licenciame-storage
AWS_REGION=us-east-1

# ── ACRCloud (reconocimiento de audio) ─────────────────────
ACRCLOUD_HOST=
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=

# ── yt-dlp ────────────────────────────────────────────────
# Navegador del que tomar cookies para descargas autenticadas
# Valores posibles: chrome, firefox, safari, edge  (dejar vacío si no aplica)
YTDLP_COOKIES_FROM_BROWSER=

# ── Instagram / Instaloader ────────────────────────────────
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Meta (Facebook / Instagram) OAuth ─────────────────────
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/v2/auth/meta/callback
META_FB_REDIRECT_URI=http://localhost:8000/api/v2/auth/meta/fb-callback

# ── Facebook OAuth (app separada para Facebook Login) ──────
FB_APP_ID=
FB_APP_SECRET=

# ── TikTok OAuth ───────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/v2/auth/tiktok/callback

# ── Aplicación ─────────────────────────────────────────────
# APP_ENV: local | staging | production
APP_ENV=local
APP_DEBUG=true
# Lista separada por comas de orígenes permitidos en CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:8081
